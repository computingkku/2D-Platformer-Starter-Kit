; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="2D-Platformer-Starter"
config/description="This starter kit provides all the essential mechanics needed to build a complete 2D platformer game in Godot 4.7. It is designed as a hands-on learning resource for students taking the Computer Game Development course at the College of Computing, Khon Kaen University."
config/version="0.1"
config/tags=PackedStringArray("2d", "framework", "platformer", "starterkit")
run/main_scene="uid://b6tvaxw54wsq0"
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/stretch_mode=4
boot_splash/image="res://Assets/Splash/splash.png"
config/icon="uid://xeh8sn4tfl0r"
boot_splash/minimum_display_time=500

[audio]

buses/default_bus_layout="uid://dly2dgklf0sh1"

[autoload]

GameManager="*res://Scenes/Managers/game_manager.gd"
SceneTransition="*res://Scenes/Managers/scene_transition.tscn"
AudioManager="*res://Scenes/Managers/audio_manager.tscn"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="2D-Platformer-Starter"

[editor_plugins]

enabled=PackedStringArray()

[global_group]

Traps=""
Enemy=""
Player=""
Bullet=""

